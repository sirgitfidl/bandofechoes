{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["node", "@playwright/test"],
        "forceConsistentCasingInFileNames": true
    },
    "include": ["playwright.config.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "playwright-report", "test-results"]
}